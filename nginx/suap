# Custom log format with request time and upstream response time
log_format suap_log '$remote_addr - $remote_user [$time_local] '
                    '"$request" $status $body_bytes_sent '
                    '"$http_referer" "$http_user_agent" '
                    'rt=$request_time uct=$upstream_connect_time uht=$upstream_header_time urt=$upstream_response_time';

# Upstream with least_conn strategy
upstream suap_server {
    least_conn;
    server 127.0.0.1:8000;
}

# Main server block (port 80)
server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/suap_access.log suap_log;
    error_log /var/log/nginx/suap_error.log;

    client_max_body_size 100m;

    # Proxy buffers (for large headers)
    proxy_buffer_size 128k;
    proxy_buffers 4 256k;
    proxy_busy_buffers_size 256k;

    # Static files
    location /static/ {
        alias /opt/suap/deploy/static/;
        expires 30d;
        access_log off;
    }

    # Media files
    location /media/ {
        alias /opt/suap/deploy/media/;
        expires 30d;
        access_log off;
    }

    # Proxy to SUAP
    location / {
        proxy_pass http://suap_server;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
    }

    # Custom error pages
    error_page 500 502 503 504 /500.html;
    error_page 413 /413.html;

    location = /500.html {
        root /opt/suap/deploy/templates;
        internal;
    }

    location = /413.html {
        root /opt/suap/deploy/templates;
        internal;
    }
}

# Secondary server block (port 8001)
server {
    listen 8001;
    server_name _;

    access_log /var/log/nginx/suap_8001_access.log suap_log;
    error_log /var/log/nginx/suap_8001_error.log;

    client_max_body_size 100m;

    proxy_buffer_size 128k;
    proxy_buffers 4 256k;
    proxy_busy_buffers_size 256k;

    location / {
        proxy_pass http://suap_server;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
    }
}
